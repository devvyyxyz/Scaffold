{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the main Scaffold window.",
  "windows": ["main", "onboarding", "docs"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-set-title",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-close",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "store:default",
    "shell:default",
    "shell:allow-open"
  ]
}