{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scaffold",
  "version": "0.1.0",
  "identifier": "app.scaffold.builder",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Scaffold",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      },
      {
        "label": "onboarding",
        "title": "Scaffold Setup",
        "url": "index.html?window=onboarding",
        "width": 600,
        "height": 720,
        "minWidth": 520,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": false
      },
      {
        "label": "docs",
        "title": "Scaffold Documentation",
        "url": "index.html?window=docs",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Visual React site builder",
    "longDescription": "Local-first visual builder for composing React sites and exporting clean, framework-ready code."
  }
}