{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the main Scaffold window.",
  "windows": ["main", "onboarding"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "store:default",
    "shell:default",
    "shell:allow-open"
  ]
}
